{
  "expo": {
    "name": "OneTap",
    "slug": "onetap-mobile",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0F0A1E",
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0A1E"
      },
      "package": "com.onetap.mobile",
      "softwareKeyboardLayoutMode": "pan",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "onetap"
            },
            {
              "scheme": "https",
              "host": "one-tap-ten.vercel.app",
              "pathPrefix": "/view"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.onetap.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-document-picker",
      "expo-av"
    ],
    "scheme": "onetap",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e6d4198b-8795-43e5-bac3-e000e1148e26"
      }
    }
  }
}
